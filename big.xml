<?xml version="1.0" encoding="UTF-8"?>
<testset xmlns="http://cpee.org/ns/properties/2.0">
  <executionhandler>ruby</executionhandler>

  <dataelements>
    <train_found/>
    <page_exhausted/>
    <seat_confirmed/>
    <ticket_class/>
    <payment_done/>
    <purchase_complete/>
    <seats_available/>
    <payment_method/>
    <price_accepted/>
    <email_checked/>
    <email_logged_in/>
    <wants_updates/>
    <update_channel/>
  </dataelements>

  <endpoints>
    <timeout>https-post://cpee.org/services/timeout.php</timeout>
    <search>https-get://station.example.org/trains/search</search>
    <seat>https-post://station.example.org/seat/select</seat>
    <payment>https-post://station.example.org/payment/process</payment>
    <ticket>https-post://station.example.org/ticket/issue</ticket>
    <notify>https-post://station.example.org/customer/notify</notify>
    <log>https-post://station.example.org/log</log>
  </endpoints>

  <attributes>
    <modeltype>CPEE</modeltype>
    <theme>extended</theme>
    <info>Train Station Ticket Purchase - 23 Elements</info>
    <model_uuid>77777777-7777-7777-7777-777777777777</model_uuid>
    <design_dir>Workflows.dir/Station.dir/TicketPurchase.dir/</design_dir>
    <design_stage>development</design_stage>
  </attributes>

  <description>
    <description xmlns="http://cpee.org/ns/description/1.0">

      <!-- 1 -->
      <manipulate id="a1" label="Start Purchase">
        <code>
          data.train_found       = false
          data.page_exhausted    = false
          data.seat_confirmed    = false
          data.ticket_class      = 'second'
          data.payment_done      = false
          data.purchase_complete = false
          data.seats_available   = false
          data.payment_method    = 'card'
          data.price_accepted    = false
          data.current_page      = 1
          data.max_pages         = 3
          data.email_checked     = false
          data.email_logged_in   = false
          data.wants_updates     = true
          data.update_channel    = 'sms'
        </code>
      </manipulate>

      <!-- 2 -->
      <call id="a2" endpoint="log">
        <parameters>
          <label>Log Session Start</label>
          <arguments>
            <action>session_started</action>
          </arguments>
        </parameters>
      </call>

      <!-- LOOP 1 (outer): entire purchase, retry if abandoned -->
      <loop mode="post_test" condition="data.purchase_complete == false">

        <!-- LOOP 2 (mid): search trains until one is found -->
        <loop mode="post_test" condition="data.train_found == false">

          <!-- 3 -->
          <call id="a3" endpoint="search">
            <parameters>
              <label>Choose the city you want to go to</label>
              <arguments>
                <route>any destination</route>
                <date>today</date>
              </arguments>
            </parameters>
          </call>

          <!-- LOOP 3 (inner): page through results until train found -->
          <loop mode="post_test" condition="data.train_found == false &amp;&amp; data.page_exhausted == false">

            <!-- 4 -->
            <call id="a4" endpoint="search">
              <parameters>
                <label>Load Results Page</label>
                <arguments>
                  <page>!data.current_page</page>
                </arguments>
              </parameters>
              <code>
                <prepare/>
                <finalize output="result">data.seats_available = result['available'] rescue false</finalize>
                <update output="result"/>
                <rescue output="result"/>
              </code>
            </call>

            <!-- 5 -->
            <choose id="c1" mode="exclusive" label="Type the city name">
              <alternative condition="seats_available == true">
                <!-- 6 -->
                <manipulate id="a5" label="Select Train">
                  <code>data.train_found = true</code>
                </manipulate>
              </alternative>
              <otherwise>
                <!-- 7 -->
                <manipulate id="a6" label="Look for other trains">
                  <code>
                    data.current_page += 1
                    data.page_exhausted = data.current_page > data.max_pages
                  </code>
                </manipulate>
              </otherwise>
            </choose>

          </loop>
          <!-- end LOOP 3 -->

          <!-- 8 -->
          <choose id="c2" mode="exclusive" label="train_found == false">
            <alternative condition="">
              <!-- 9 -->
              <call id="a7" endpoint="notify">
                <parameters>
                  <label>Notify: No Trains Found</label>
                  <arguments>
                    <reason>all pages exhausted</reason>
                  </arguments>
                </parameters>
              </call>
              <!-- 10 -->
              <manipulate id="a8" label="Reset Search">
                <code>
                  data.current_page   = 1
                  data.page_exhausted = false
                </code>
              </manipulate>
            </alternative>
            <otherwise>
              <!-- 11 -->
              <call id="a9" endpoint="notify">
                <parameters>
                  <label>Show Train Details</label>
                  <arguments>
                    <action>display</action>
                  </arguments>
                </parameters>
              </call>
            </otherwise>
          </choose>

        </loop>
        <!-- end LOOP 2 -->

        <!-- LOOP 4: select and confirm seat -->
        <loop mode="post_test" condition="data.seat_confirmed == false">

          <!-- 12 -->
          <choose id="c3" mode="exclusive" label="Choose Seat Class">
            <alternative condition="ticket_class == first">
              <!-- 13 -->
              <call id="a10" endpoint="seat">
                <parameters>
                  <label>Select First Class Seat</label>
                  <arguments>
                    <class>first</class>
                  </arguments>
                </parameters>
              </call>
            </alternative>
            <otherwise>
              <!-- 14 -->
              <call id="a11" endpoint="seat">
                <parameters>
                  <label>Select Second Class Seat</label>
                  <arguments>
                    <class>second</class>
                  </arguments>
                </parameters>
              </call>
            </otherwise>
          </choose>

          <!-- 15 -->
          <call id="a12" endpoint="seat">
            <parameters>
              <label>Confirm Seat</label>
              <arguments>
                <action>confirm</action>
              </arguments>
            </parameters>
            <code>
              <prepare/>
              <finalize output="result">data.seat_confirmed = result['confirmed'] rescue true</finalize>
              <update output="result"/>
              <rescue output="result"/>
            </code>
          </call>

        </loop>
        <!-- end LOOP 4 -->

        <!-- 16 -->
        <call id="a13" endpoint="notify">
          <parameters>
            <label>Show Price Summary</label>
            <arguments>
              <class>!data.ticket_class</class>
            </arguments>
          </parameters>
          <code>
            <prepare/>
            <finalize output="result">data.price_accepted = result['accepted'] rescue true</finalize>
            <update output="result"/>
            <rescue output="result"/>
          </code>
        </call>

        <!-- LOOP 5: retry payment until successful -->
        <loop mode="post_test" condition="data.payment_done == false">

          <!-- 17 -->
          <choose id="c4" mode="exclusive" label="Chooese Payment Way">
            <alternative condition="payment_method == card">
              <!-- 18 -->
              <call id="a14" endpoint="payment">
                <parameters>
                  <label>Pay by Card</label>
                  <arguments>
                    <method>card</method>
                  </arguments>
                </parameters>
                <code>
                  <prepare/>
                  <finalize output="result">data.payment_done = result['success'] rescue false</finalize>
                  <update output="result"/>
                  <rescue output="result">data.payment_done = false</rescue>
                </code>
              </call>
            </alternative>
            <otherwise>
              <!-- 19 -->
              <call id="a15" endpoint="payment">
                <parameters>
                  <label>Pay by Cash</label>
                  <arguments>
                    <method>cash</method>
                  </arguments>
                </parameters>
                <code>
                  <prepare/>
                  <finalize output="result">data.payment_done = result['success'] rescue true</finalize>
                  <update output="result"/>
                  <rescue output="result">data.payment_done = false</rescue>
                </code>
              </call>
            </otherwise>
          </choose>

          <!-- 20 -->
          <manipulate id="a16" label="Check Payment Result">
            <code>
              data.purchase_complete = data.payment_done
            </code>
          </manipulate>

        </loop>
        <!-- end LOOP 5 -->

      </loop>
      <!-- end LOOP 1 -->

      <!-- 21 -->
      <call id="a17" endpoint="ticket">
        <parameters>
          <label>Print Ticket</label>
          <arguments>
            <format>paper</format>
          </arguments>
        </parameters>
      </call>

      <!-- LOOP 6: check email login, send digital ticket only if logged in -->
      <loop mode="post_test" condition="data.email_checked == false">

        <!-- 22 -->
        <call id="a18" endpoint="notify">
          <parameters>
            <label>Check Email Login</label>
            <arguments>
              <action>check_login</action>
            </arguments>
          </parameters>
          <code>
            <prepare/>
            <finalize output="result">data.email_logged_in = result['logged_in'] rescue false</finalize>
            <update output="result"/>
            <rescue output="result"/>
          </code>
        </call>

        <!-- 23 -->
        <manipulate id="a20" label="Mark Email Checked">
          <code>data.email_checked = true</code>
        </manipulate>

      </loop>
      <!-- end LOOP 6 -->

      <!-- 24 -->
      <choose id="c5" mode="exclusive" label="Log in your Email">
        <alternative condition="email_logged_in == true">

          <call id="a21" endpoint="ticket">
            <parameters>
              <label>Send Digital Ticket</label>
              <arguments>
                <format>email</format>
              </arguments>
            </parameters>
          </call>

          <!-- 25 (nested inside email logged in) -->
          <choose id="c6" mode="exclusive" label="wants_updates == true">
            <alternative condition="">

              <!-- 26 -->
              <choose id="c7" mode="exclusive" label="Subscribe Updates">
                <alternative condition="update_channel == sms">
                  <call id="a23" endpoint="notify">
                    <parameters>
                      <label>Subscribe SMS Updates</label>
                      <arguments>
                        <channel>sms</channel>
                      </arguments>
                    </parameters>
                  </call>
                </alternative>
                <otherwise>
                  <call id="a24" endpoint="notify">
                    <parameters>
                      <label>Subscribe Email Updates</label>
                      <arguments>
                        <channel>email</channel>
                      </arguments>
                    </parameters>
                  </call>
                </otherwise>
              </choose>

            </alternative>
            <otherwise>
              <manipulate id="a25" label="Skip Updates">
                <code>data.updates_skipped = true</code>
              </manipulate>
            </otherwise>
          </choose>

        </alternative>
        <otherwise>
          <manipulate id="a22" label="Skip Digital Ticket">
            <code>data.email_skipped = true</code>
          </manipulate>
        </otherwise>
      </choose>

      <!-- 27 -->
      <call id="a19" endpoint="log">
        <parameters>
          <label>Log Transaction</label>
          <arguments>
            <status>completed</status>
            <class>!data.ticket_class</class>
            <method>!data.payment_method</method>
          </arguments>
        </parameters>
      </call>

    </description>
  </description>

  <transformation>
    <description type="copy"/>
  </transformation>
</testset>
