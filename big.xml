<?xml version="1.0" encoding="UTF-8"?>
<testset xmlns="http://cpee.org/ns/properties/2.0">
  <executionhandler>ruby</executionhandler>

  <dataelements>
    <course_found/>
    <page_exhausted/>
    <slot_confirmed/>
    <course_level/>
    <payment_done/>
    <enrollment_complete/>
    <seats_available/>
    <payment_method/>
    <prereq_passed/>
    <email_checked/>
    <email_logged_in/>
    <wants_reminders/>
    <reminder_channel/>
  </dataelements>

  <endpoints>
    <timeout>https-post://cpee.org/services/timeout.php</timeout>
    <search>https-get://university.example.org/courses/search</search>
    <slot>https-post://university.example.org/slot/reserve</slot>
    <payment>https-post://university.example.org/fees/pay</payment>
    <enrollment>https-post://university.example.org/enrollment/confirm</enrollment>
    <notify>https-post://university.example.org/student/notify</notify>
    <log>https-post://university.example.org/log</log>
  </endpoints>

  <attributes>
    <modeltype>CPEE</modeltype>
    <theme>extended</theme>
    <info>University Course Registration - 23 Elements</info>
    <model_uuid>88888888-8888-8888-8888-888888888888</model_uuid>
    <design_dir>Workflows.dir/University.dir/CourseRegistration.dir/</design_dir>
    <design_stage>development</design_stage>
  </attributes>

  <description>
    <description xmlns="http://cpee.org/ns/description/1.0">

      <!-- 1 -->
      <manipulate id="a1" label="Start Registration">
        <code>
          data.course_found        = false
          data.page_exhausted      = false
          data.slot_confirmed      = false
          data.course_level        = 'undergraduate'
          data.payment_done        = false
          data.enrollment_complete = false
          data.seats_available     = false
          data.payment_method      = 'online'
          data.prereq_passed       = false
          data.current_page        = 1
          data.max_pages           = 3
          data.email_checked       = false
          data.email_logged_in     = false
          data.wants_reminders     = true
          data.reminder_channel    = 'sms'
        </code>
      </manipulate>

      <!-- 2 -->
      <call id="a2" endpoint="log">
        <parameters>
          <label>Log Session Start</label>
          <arguments>
            <action>session_started</action>
          </arguments>
        </parameters>
      </call>

      <!-- LOOP 1 (outer): entire registration, retry if incomplete -->
      <loop mode="post_test" condition="data.enrollment_complete == false">

        <!-- LOOP 2 (mid): search courses until one is found -->
        <loop mode="post_test" condition="data.course_found == false">

          <!-- 3 -->
          <call id="a3" endpoint="search">
            <parameters>
              <label>Select course name</label>
              <arguments>
                <subject>any department</subject>
                <semester>current</semester>
              </arguments>
            </parameters>
          </call>

          <!-- LOOP 3 (inner): page through results until course found -->
          <loop mode="post_test" condition="data.course_found == false &amp;&amp; data.page_exhausted == false">

            <!-- 4 -->
            <call id="a4" endpoint="search">
              <parameters>
                <label>Load Results Page</label>
                <arguments>
                  <page>!data.current_page</page>
                </arguments>
              </parameters>
              <code>
                <prepare/>
                <finalize output="result">data.seats_available = result['available'] rescue false</finalize>
                <update output="result"/>
                <rescue output="result"/>
              </code>
            </call>

            <!-- 5 -->
            <choose id="c1" mode="exclusive" label="seats_available == true">
              <alternative condition="">
                <!-- 6 -->
                <manipulate id="a5" label="Select Course">
                  <code>data.course_found = true</code>
                </manipulate>
              </alternative>
              <otherwise>
                <!-- 7 -->
                <manipulate id="a6" label="Reselect Courses">
                  <code>
                    data.current_page += 1
                    data.page_exhausted = data.current_page > data.max_pages
                  </code>
                </manipulate>
              </otherwise>
            </choose>

          </loop>
          <!-- end LOOP 3 -->

          <!-- 8 -->
          <choose id="c2" mode="exclusive" label="course_found == false">
            <alternative condition="">
              <!-- 9 -->
              <call id="a7" endpoint="notify">
                <parameters>
                  <label>Notify No Courses Found</label>
                  <arguments>
                    <reason>all pages exhausted</reason>
                  </arguments>
                </parameters>
              </call>
              <!-- 10 -->
              <manipulate id="a8" label="Reset Search">
                <code>
                  data.current_page   = 1
                  data.page_exhausted = false
                </code>
              </manipulate>
            </alternative>
            <otherwise>
              <!-- 11 -->
              <call id="a9" endpoint="notify">
                <parameters>
                  <label>Show Course Details</label>
                  <arguments>
                    <action>display</action>
                  </arguments>
                </parameters>
              </call>
            </otherwise>
          </choose>

        </loop>
        <!-- end LOOP 2 -->

        <!-- LOOP 4: check prerequisites and confirm slot -->
        <loop mode="post_test" condition="data.slot_confirmed == false">

          <!-- 12 -->
          <choose id="c3" mode="exclusive" label="course_level == master">
            <alternative condition="">
              <!-- 13 -->
              <call id="a10" endpoint="slot">
                <parameters>
                  <label>Reserve Master Slot</label>
                  <arguments>
                    <level>master</level>
                  </arguments>
                </parameters>
              </call>
            </alternative>
            <otherwise>
              <!-- 14 -->
              <call id="a11" endpoint="slot">
                <parameters>
                  <label>Reserve Undergraduate Slot</label>
                  <arguments>
                    <level>undergraduate</level>
                  </arguments>
                </parameters>
              </call>
            </otherwise>
          </choose>

          <!-- 15 -->
          <call id="a12" endpoint="slot">
            <parameters>
              <label>Confirm Slot</label>
              <arguments>
                <action>confirm</action>
              </arguments>
            </parameters>
            <code>
              <prepare/>
              <finalize output="result">data.slot_confirmed = result['confirmed'] rescue true</finalize>
              <update output="result"/>
              <rescue output="result"/>
            </code>
          </call>

        </loop>
        <!-- end LOOP 4 -->

        <!-- 16 -->
        <call id="a13" endpoint="notify">
          <parameters>
            <label>Show Fee Summary</label>
            <arguments>
              <level>!data.course_level</level>
            </arguments>
          </parameters>
          <code>
            <prepare/>
            <finalize output="result">data.prereq_passed = result['accepted'] rescue true</finalize>
            <update output="result"/>
            <rescue output="result"/>
          </code>
        </call>

        <!-- LOOP 5: retry payment until successful -->
        <loop mode="post_test" condition="data.payment_done == false">

          <!-- 17 -->
          <choose id="c4" mode="exclusive" label="payment_method == online">
            <alternative condition="data.payment_method == 'online'">
              <!-- 18 -->
              <call id="a14" endpoint="payment">
                <parameters>
                  <label>Pay Online</label>
                  <arguments>
                    <method>online</method>
                  </arguments>
                </parameters>
                <code>
                  <prepare/>
                  <finalize output="result">data.payment_done = result['success'] rescue false</finalize>
                  <update output="result"/>
                  <rescue output="result">data.payment_done = false</rescue>
                </code>
              </call>
            </alternative>
            <otherwise>
              <!-- 19 -->
              <call id="a15" endpoint="payment">
                <parameters>
                  <label>Pay at Cashier</label>
                  <arguments>
                    <method>cashier</method>
                  </arguments>
                </parameters>
                <code>
                  <prepare/>
                  <finalize output="result">data.payment_done = result['success'] rescue true</finalize>
                  <update output="result"/>
                  <rescue output="result">data.payment_done = false</rescue>
                </code>
              </call>
            </otherwise>
          </choose>

          <!-- 20 -->
          <manipulate id="a16" label="Check Payment Result">
            <code>
              data.enrollment_complete = data.payment_done
            </code>
          </manipulate>

        </loop>
        <!-- end LOOP 5 -->

      </loop>
      <!-- end LOOP 1 -->

      <!-- 21 -->
      <call id="a17" endpoint="enrollment">
        <parameters>
          <label>Print Enrollment Confirmation</label>
          <arguments>
            <format>paper</format>
          </arguments>
        </parameters>
      </call>

      <!-- LOOP 6: check email login, send digital confirmation only if logged in -->
      <loop mode="post_test" condition="data.email_checked == false">

        <!-- 22 -->
        <call id="a18" endpoint="notify">
          <parameters>
            <label>Check Email Login</label>
            <arguments>
              <action>check_login</action>
            </arguments>
          </parameters>
          <code>
            <prepare/>
            <finalize output="result">data.email_logged_in = result['logged_in'] rescue false</finalize>
            <update output="result"/>
            <rescue output="result"/>
          </code>
        </call>

        <!-- 23 -->
        <manipulate id="a20" label="Mark Email Checked">
          <code>data.email_checked = true</code>
        </manipulate>

      </loop>
      <!-- end LOOP 6 -->

      <!-- 24 -->
      <choose id="c5" mode="exclusive" label="email_logged_in == true">
        <alternative condition="">

          <call id="a21" endpoint="enrollment">
            <parameters>
              <label>Send Digital Confirmation</label>
              <arguments>
                <format>email</format>
              </arguments>
            </parameters>
          </call>

          <!-- 25 (nested inside email logged in) -->
          <choose id="c6" mode="exclusive" label="wants_reminders == true">
            <alternative condition="">

              <!-- 26 -->
              <choose id="c7" mode="exclusive" label="reminder_channel == sms">
                <alternative condition="data.reminder_channel == 'sms'">
                  <call id="a23" endpoint="notify">
                    <parameters>
                      <label>Subscribe SMS Reminders</label>
                      <arguments>
                        <channel>sms</channel>
                      </arguments>
                    </parameters>
                  </call>
                </alternative>
                <otherwise>
                  <call id="a24" endpoint="notify">
                    <parameters>
                      <label>Subscribe Email Reminders</label>
                      <arguments>
                        <channel>email</channel>
                      </arguments>
                    </parameters>
                  </call>
                </otherwise>
              </choose>

            </alternative>
            <otherwise>
              <manipulate id="a25" label="Skip Reminders">
                <code>data.reminders_skipped = true</code>
              </manipulate>
            </otherwise>
          </choose>

        </alternative>
        <otherwise>
          <manipulate id="a22" label="Skip Digital Confirmation">
            <code>data.email_skipped = true</code>
          </manipulate>
        </otherwise>
      </choose>

      <!-- 27 -->
      <call id="a19" endpoint="log">
        <parameters>
          <label>Log Transaction</label>
          <arguments>
            <status>completed</status>
            <level>!data.course_level</level>
            <method>!data.payment_method</method>
          </arguments>
        </parameters>
      </call>

    </description>
  </description>

  <transformation>
    <description type="copy"/>
  </transformation>
</testset>